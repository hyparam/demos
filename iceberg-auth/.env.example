# Copy to .env.local and fill in. Vite injects VITE_* vars at build time.

# AWS region for Cognito, S3, and Bedrock. All three must be in the same region
# for this demo's URL builders to work without changes.
VITE_AWS_REGION=us-east-1

# Cognito hosted UI base (no trailing slash). Set up under
# "App integration > Domain" on the User Pool.
VITE_COGNITO_DOMAIN=https://your-prefix.auth.us-east-1.amazoncognito.com

# Public app-client ID. The client must NOT have a client secret (SPA flow),
# and must have "Authorization code grant" + the openid/email/profile scopes
# enabled, with this app's URL registered as a callback + logout URL.
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# User Pool that hosts the whitelisted user. Used as the Logins key for
# Cognito Identity (cognito-idp.<region>.amazonaws.com/<userPoolId>).
VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX

# Identity Pool that mints AWS temp creds for authenticated users from the
# User Pool above. Its "authenticated" IAM role is what gates S3 + Bedrock.
VITE_COGNITO_IDENTITY_POOL_ID=us-east-1:00000000-0000-0000-0000-000000000000

# Client-side guard for clarity. Real enforcement lives in the User Pool
# (only this user exists) and the IAM trust/permissions policies.
VITE_ALLOWED_EMAIL=kenny@hyperparam.app

# Private S3 bucket holding Iceberg tables. Must allow s3:GetObject /
# s3:ListBucket on the authenticated role, and have CORS configured to allow
# this app's origin with GET, HEAD, and Range/Authorization headers.
VITE_S3_BUCKET=hyperparam-private

# Optional subpath under the bucket where Iceberg tables live.
# Example: tables at s3://hyperparam-private/warehouse/<table>/metadata/...
VITE_S3_TABLE_PREFIX=warehouse

# Bedrock model id to call via InvokeModel. Must be enabled on the account
# in this region (Bedrock console > Model access). Claude 4.x requires a
# cross-region inference profile — prefix with `us.` / `eu.` / `apac.` to match
# the region group where you have access.
VITE_BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
